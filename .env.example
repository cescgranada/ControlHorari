# Configuració de Supabase
# Per obtenir aquestes claus:
# 1. Crea un compte a https://supabase.com
# 2. Crea un nou projecte
# 3. Vés a Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Aquesta clau és opcional (només per a operacions administratives)
# La pots trobar a Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# Secret per protegir les rutes de cron job (Vercel les crida automàticament)
# Genera un valor aleatori llarg i posa'l també a Vercel > Settings > Environment Variables
CRON_SECRET=UN_SECRET_LLARG_I_ALEATORI
