# Aquest és un exemple de com hauria de quedar el teu fitxer .env
# amb valors ficticis. Substitueix els valors amb les teves claus reals.
# ============================================

# Project URL del teu projecte "ControlHorariNP"
# La trobes a: Settings → API → Project URL
# Exemple: https://abcdefg123456.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://abcdefg123456.supabase.co

# Anon Key pública
# La trobes a: Settings → API → API Keys → anon / public
# Comença amb eyJ... i és molt llarga
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImFiY2RlZmdoIiwicm9sZSI6ImFub24iLCJpYXQiOjE3MDk4NzM2MDAsImV4cCI6MjAyNTQ0OTYwMH0.example_key_public_anon

# URL local de l'aplicació (no canviar)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Service Role Key (opcional)
# La trobes a: Settings → API → API Keys → service_role
# Comença amb eyJ... i és molt llarga
# IMPORTANT: No la comparteixis mai públicament
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImFiY2RlZmdoIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTcwOTg3MzYwMCwiZXhwIjoyMDI1NDQ5NjAwf0.example_key_service_role

# ============================================
